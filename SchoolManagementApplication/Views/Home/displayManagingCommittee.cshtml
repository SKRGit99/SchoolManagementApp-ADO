@{
    ViewData["Title"] = "Managing Committee";
    Layout = "~/Views/_Layout.cshtml";
}

<!-- Managing Committee Section -->
<div class="container py-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-primary">Managing Committee</h2>
        <p class="text-dark">
            Meet the dedicated members of our Managing Committee who guide SKR International School
            with vision, integrity, and commitment to excellence in education.
        </p>
    </div>

    <div class="row justify-content-center g-4">
        <!-- Member 1 -->
        <div class="col-md-4 col-lg-3 text-center">
            <img src="~/images/school director 002.png" class="img-fluid rounded-circle shadow-sm mb-3" alt="Director" style="max-height:200px;">
            <h5 class="fw-bold text-primary">Mrs. Anupam Kumari</h5>
            <p class="text-dark mb-1">Founder & Director</p>
            <p class="small text-muted">M.A. (Education), B.Ed.</p>
        </div>

        <!-- Member 2 -->
        <div class="col-md-4 col-lg-3 text-center">
            <img src="~/images/sampat_kumar_rahul_official_001.jpg" class="img-fluid rounded-circle shadow-sm mb-3" alt="Principal" style="max-height:200px;">
            <h5 class="fw-bold text-primary">Mr. Sampat Kumar Rahul</h5>
            <p class="text-dark mb-1">Principal</p>
            <p class="small text-muted">B.E. Mechanical Engg.</p>
        </div>

        <!-- Member 2 -->
        <div class="col-md-4 col-lg-3 text-center">
            <img src="~/images/santosh_babul_img.jpg" class="img-fluid rounded-circle shadow-sm mb-3" alt="Principal" style="max-height:200px;">
            <h5 class="fw-bold text-primary">Mr. Santosh Kumar Babul</h5>
            <p class="text-dark mb-1">Vice Principal</p>
            <p class="small text-muted">B.E. Mechanical Engg.</p>
        </div>

        <!-- Member 3 -->
        <div class="col-md-4 col-lg-3 text-center">
            <img src="~/images/img-20230320-wa0006.jpg" class="img-fluid rounded-circle shadow-sm mb-3" alt="Vice Principal" style="max-height:200px;">
            <h5 class="fw-bold text-primary">Mr. Kaushalendra Kumar</h5>
            <p class="text-dark mb-1">Vice Principal</p>
            <p class="small text-muted">M.Sc. (Physics),B.E.(Mechanical), B.Ed.</p>
        </div>
        <!-- Member 3 -->
        <div class="col-md-4 col-lg-3 text-center">
            <img src="~/images/pranay ji.jpeg" class="img-fluid rounded-circle shadow-sm mb-3" alt="Vice Principal" style="max-height:200px;">
            <h5 class="fw-bold text-primary">Mr. Kumar Pranay</h5>
            <p class="text-dark mb-1">Vice Principal</p>
            <p class="small text-muted">M.Sc. (Math),B.Tech.(Mechanical)</p>
        </div>
    </div>
</div>

