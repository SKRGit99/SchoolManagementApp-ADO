        </div>
        <div class="col-md-4 text-center">
            <img src="~/images/School Class room.png" class="img-fluid rounded shadow-sm mb-3" alt="Tech Savvy Classes" />
        </div>

        <!-- Image 2 -->
        <div class="col-md-4 text-center">
            <img src="~/images/Critical thinking Lab.png" class="img-fluid rounded shadow-sm" alt="Classroom" />
        </div>

        <!-- Image 3 -->
        <div class="col-md-4 text-center">
            <img src="~/images/School laboratory 001.jpg" class="img-fluid rounded shadow-sm" alt="Laboratory" />
        </div>

        <!-- Image 4 -->
        <div class="col-md-4 text-center">
            <img src="~/images/AI Lab Image 002.png" class="img-fluid rounded shadow-sm" alt="Activity Room" />
        </div>

        <!-- Image 5 -->
        <div class="col-md-4 text-center">
            <img src="~/images/Dance and Music.png" class="img-fluid rounded shadow-sm" alt="Dance Studio" />
