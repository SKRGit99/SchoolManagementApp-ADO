@{
    ViewData["Title"] = "About Us - SKR International School";
    Layout = "~/Views/_Layout.cshtml";
}

<!-- About Us Section -->
<div class="container py-5">
    <div class="row align-items-center g-5">
        <!-- Text Section -->
        <div class="col-12 col-lg-7">
            <h2 class="fw-bold text-primary mb-3">About Us</h2>
            <p class="lead text-muted mb-3">
                At SKR International School, we believe education is more than academics — it is about
                nurturing curiosity, creativity, and character. Our institution stands as a beacon of
                excellence, blending tradition with innovation to prepare students for a dynamic future.
            </p>
            <p class="text-muted mb-3">
                With state-of-the-art facilities, dedicated educators, and a vibrant learning environment,
                we empower students to explore their passions, embrace challenges, and achieve their dreams.
                From tech-savvy classrooms to AI labs, we ensure every child has access to the tools and
                guidance needed to thrive in the modern world.
            </p>
            <p class="text-muted">
                SKR International School is not just a place to learn — it is a community where values,
                leadership, and lifelong friendships are built. Together, we inspire the leaders of tomorrow.
            </p>
        </div>

        <!-- Image Section -->
        <div class="col-12 col-lg-5 text-center">
            <img src="~/images/school background image final.png"
                 class="img-fluid rounded shadow-lg"
                 alt="About SKR International School"
                 style="max-height:400px;" />
        </div>
    </div>
</div>

<!-- School Gallery Section -->
