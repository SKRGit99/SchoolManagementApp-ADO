@{
    ViewData["Title"] = "ABC International School - Home";
    Layout = "~/Views/_Layout.cshtml";
}
<div class="container py-5">
    <div class="row align-items-center g-5">
        <!-- Director Image -->
        <div class="col-12 col-md-5 text-center">
            <img src="~/images/school director 002.png" class="img-fluid rounded shadow-lg" alt="school director" style="max-height:400px;" />
        </div>

        <!-- Director Message -->
        <div class="col-12 col-md-7">
            <h2 class="fw-bold text-primary mb-3">From the Director's Desk</h2>
            <p class="lead text-muted">
                Welcome to SKR International School, where we believe education is the key to unlocking
                every child’s potential. Our mission is to provide a nurturing environment that fosters
                creativity, innovation, and lifelong learning.
            </p>
            <p>
                As Director, I am proud to lead a team of dedicated educators who inspire students to
                achieve excellence not only in academics but also in character and values. Together,
                we strive to create a community where curiosity thrives and every student feels empowered
                to shape their future.
            </p>
            <p class="fw-bold text-secondary mb-0">
                — Director, SKR International School
            </p>
        </div>
        
        
    </div>
</div>


<!-- Director's Initiatives Section -->
<div class="container py-5">
    <h2 class="fw-bold text-primary mb-4 text-center">Director's Initiatives</h2>
    <p class="text-muted text-center mb-5">
        At SKR International School, our Director champions innovative initiatives that enrich student learning
        and foster holistic development. Explore some of the key programs below.
    </p>

    <div class="row g-4">
        <!-- Play and Learn -->
        <div class="col-md-4 text-center">
            <img src="~/images/Sports activities 003.png" class="img-fluid rounded shadow-sm mb-3" alt="PlayAndLearn" />
            <h5 class="fw-bold">Play and Learn</h5>
            <p class="text-muted">Interactive sessions that blend fun with academics, encouraging curiosity and joyful learning.</p>
        </div>

        <!-- Critical Thinking -->
        <div class="col-md-4 text-center">
            <img src="~/images/Critical thinking Lab.png" class="img-fluid rounded shadow-sm mb-3" alt="PlayAndLearn" />
            <h5 class="fw-bold">Critical Thinking</h5>
            <p class="text-muted">Programs designed to sharpen analytical skills and empower students to solve real-world problems.</p>
        </div>

        <!-- Dance Studio -->
        <div class="col-md-4 text-center">
            <img src="~/images/Dance and Music.png" class="img-fluid rounded shadow-sm mb-3" alt="Dance Studio" />
            <h5 class="fw-bold">Dance Studio</h5>
            <p class="text-muted">A creative space for extracurricular activities, nurturing talent in dance, music, and performance arts.</p>
        </div>
    </div>
</div>





<!-- Container 1: Logo + Contact Details -->
<div class="container py-5">
    <div class="row align-items-center justify-content-between">
        <!-- Logo -->
        <div class="col-12 col-lg-3">
            <img src="~/images/school logo.png" class="img-fluid" alt="ABC International School Logo" style="max-height:200px;" />
        </div>
        <div class="col-12 col-lg-3">
            <h3 class="fw-bold text-primary mb-3">Contact Us</h3>
            <p class="lead text-muted mb-1">
                SKR International School<br />
                123 Learning Avenue, Mulshi, Maharashtra, India
            </p>
            <p class="mb-0">
                Phone: +91 98765 43210<br />
                Email: info@abcschool.com
            </p>
        </div>
        <div class="col-12 col-lg-6 align-items-center">
            <h3 class="fw-bold text-primary  mb-3">Important Links</h3>
            <div class="d-flex flex-wrap gap-3">
                <a href="https://www.cbse.gov.in" target="_blank" class="btn btn-outline-primary px-4 py-2">
                    <i class="bi bi-link-45deg me-2"></i> CBSE Official Website
                </a>
                <a href="https://nta.ac.in" target="_blank" class="btn btn-outline-primary px-4 py-2">
                    <i class="bi bi-journal-text me-2"></i> National Testing Agency (NTA)
                </a>
                <a href="https://www.olympiadsuccess.com" target="_blank" class="btn btn-outline-primary px-4 py-2">
                    <i class="bi bi-award me-2"></i> Olympiad Success
                </a>
                <a href="https://www.khanacademy.org" target="_blank" class="btn btn-outline-primary px-4 py-2">
                    <i class="bi bi-book me-2"></i> Khan Academy
                </a>
                <a href="https://www.unacademy.com" target="_blank" class="btn btn-outline-primary px-4 py-2">
                    <i class="bi bi-mortarboard me-2"></i> Unacademy
                </a>
                <a href="https://www.coursera.org" target="_blank" class="btn btn-outline-primary px-4 py-2">
                    <i class="bi bi-globe me-2"></i> Coursera
                </a>
            </div>
        </div>

    </div>
</div>
