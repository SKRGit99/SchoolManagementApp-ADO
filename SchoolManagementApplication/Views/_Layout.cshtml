@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> signInManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProdApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DevApp.styles.css" asp-append-version="true" />
   
 
    <style>
        html, body {
            height: 100%; /* full viewport height */
            margin: 0;
            display: flex;
            flex-direction: column;
        }

        main {
            flex: 1; /* pushes footer down */
            min-height: 600px; /* ensures footer after certain height */
        }

        footer {
            background-color: #343a40;
            color: #fff;
            text-align: center;
            padding: 15px 0;
        }
    </style>

</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    SKR International School
                </a>
                
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                       <li class="nav-item">
                            <a class="nav-link text-light" asp-area=""
                               asp-controller="Home"
                               asp-action="Index">
                                Home
                            </a>
                       </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">
                                About
                            </a>

                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item"
                                       asp-area=""
                                       asp-controller="Home"
                                       asp-action="displayAboutUs">
                                        About Us
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-area=""
                                       asp-controller="Home"
                                       asp-action="displayDirectorMessage">
                                        Director's Desk
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-area=""
                                       asp-controller="SuperAdmin"
                                       asp-action="GetIndividualStudentDetailsByRegistrationId">
                                        Principal's Message
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-area=""
                                       asp-controller="SuperAdmin"
                                       asp-action="GetIndividualStudentDetailsByRegistrationId">
                                        History
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-area=""
                                       asp-controller="SuperAdmin"
                                       asp-action="GetIndividualStudentDetailsByRegistrationId">
                                        Managing Committee
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-area=""
                                       asp-controller="SuperAdmin"
                                       asp-action="GetIndividualStudentDetailsByRegistrationId">
                                        Fee Structure
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-area=""
                                       asp-controller="SuperAdmin"
                                       asp-action="GetIndividualStudentDetailsByRegistrationId">
                                        Infrastructure
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-area=""
                                       asp-controller="SuperAdmin"
                                       asp-action="GetIndividualStudentDetailsByRegistrationId">
                                        Aims and Objectives
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-area=""
                                       asp-controller="Home"
                                       asp-action="displayGallery">
                                        Gallery
                                    </a>
                                </li>

                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-light"
                               asp-area=""
                               asp-controller="Home"
                               asp-action="Index">
                                Admission Process
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-light"
                               asp-area=""
                               asp-controller="Home"
                               asp-action="Index">
                                Academic Calender
                            </a>
                        </li>
                        @if ((signInManager.IsSignedIn(User) && User.IsInRole("Admin") || (signInManager.IsSignedIn(User) && User.IsInRole("SuperAdmin"))))
                            {
                                <li class="nav-item dropdown">
                                            <a class="nav-link dropdown-toggle"
                                               role="button"
                                               data-bs-toggle="dropdown"
                                               id="myDropdown"
                                               aria-expanded="false">
                                                Employee Corner
                                            </a>

                                            <ul class="dropdown-menu dropdown-menu-dark">

                                                <li>
                                                    <a class="dropdown-item" asp-area="" asp-controller="SuperAdmin" asp-action="GetEducatorDetails">Educator Details</a>
                                                </li>
                                                <li>
                                                    <a class="dropdown-item" asp-area="" asp-controller="SuperAdmin" asp-action="GetIndividualEducatorDetailsByRegistrationId">Individual Educator Details</a>
                                                </li>


                                            </ul>
                                </li>

                                @* <li class="nav-item dropdown">
                                            <a class="nav-link dropdown-toggle"
                                                role="button"
                                                data-bs-toggle="dropdown"
                                                id="myDropdown"
                                                aria-expanded="false">
                                                Educator Corner
                                            </a>

                                            <ul class="dropdown-menu dropdown-menu-dark">
                                
                                                <li>
                                                    <a class="dropdown-item" asp-area="" asp-controller="SuperAdmin" asp-action="GetEducatorDetails">Educator Details</a>
                                                </li>
                                                <li>
                                                    <a class="dropdown-item" asp-area="" asp-controller="SuperAdmin" asp-action="GetIndividualEducatorDetailsByRegistrationId">Individual Educator Details</a>
                                                </li>
                                

                                            </ul>
                                </li> *@

                                <li class="nav-item dropdown">
                                            <a class="nav-link dropdown-toggle"
                                                role="button"
                                                data-bs-toggle="dropdown"
                                                id="myDropdown"
                                                aria-expanded="false">
                                                Student Corner
                                            </a>

                                            @*<ul class="dropdown-menu dropdown-menu-dark">
                                                <li>
                                                    <a class="dropdown-item" href="/Admin/GetStudentDetails" asp-area="" asp-controller="Admin" asp-action="GetStudentDetails">All Student Details</a>
                                                </li>

                                                <li>
                                                    <a class="dropdown-item" asp-area="" href="/Admin/GetStudentDetailsByRegistrationId" asp-controller="Admin" asp-action="GetStudentDetailsByRegistrationId">Individual Student Details</a>
                                                </li>
                                
                                                <li>
                                                    <a class="dropdown-item" asp-area="" href="/Admin/GetAllDetails" asp-controller="Admin" asp-action="GGetAllDetails">Consolidated Views</a>
                                                </li>
                                            </ul> *@
                                            <ul class="dropdown-menu dropdown-menu-dark">
                                                <li>
                                                    <a class="dropdown-item" asp-area="" asp-controller="SuperAdmin" asp-action="GetStudentDetails">All Student Details</a>
                                                </li>

                                                <li>
                                                    <a class="dropdown-item" asp-area="" asp-controller="SuperAdmin" asp-action="GetIndividualStudentDetailsByRegistrationId">Individual Student Details</a>
                                                </li>
                                            </ul>
                                </li>

                                
                        }

                        else @if (signInManager.IsSignedIn(User) && User.IsInRole("Employee"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle"
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                    Individual Employee corner
                                </a>

                                <ul class="dropdown-menu">

                                    <li>
                                        <a class="dropdown-item"
                                           asp-area=""
                                           asp-controller="StudentDetails"
                                           asp-action="getStudentDetailsForDropDown">
                                            My Details
                                        </a>
                                    </li>

                                </ul>
                            </li>
                        }
                        else @if (signInManager.IsSignedIn(User) && User.IsInRole("Educator"))
                        {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle"
                               href="#"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">
                                Individual Educator Corner
                            </a>

                                <ul class="dropdown-menu">

                                    <li>
                                        <a class="dropdown-item"
                                           asp-area=""
                                           asp-controller="StudentDetails"
                                           asp-action="getAllStudentDetails">
                                            Student Details
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item"
                                           asp-area=""
                                           asp-controller="StudentDetails"
                                           asp-action="getStudentDetailsForDropDown">
                                            My Details
                                        </a>
                                    </li>

                                </ul>
                            </li>
                        }

                        else @if (signInManager.IsSignedIn(User) && User.IsInRole("Student"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle"
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                    Individual Student Corner
                                </a>
                                <ul class="dropdown-menu">
                                    <li>
                                        <a class="dropdown-item"
                                           asp-area=""
                                           asp-controller="StudentDetails"
                                           asp-action="getAllStudentDetails">
                                            My Details
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }

                    </ul>


                    <div class="d-flex align-items-center">

                        @if (signInManager.IsSignedIn(User))
                        {
                            <div class="me-3 text-light">@User?.Identity?.Name </div>

                            <a class="btn me-3 bg-light text-dark"
                               asp-area=""
                               asp-controller="Login"
                               asp-action="Logout">
                                Logout
                            </a>
                        }
                        else
                        {
                            <a class="btn me-3 bg-light text-dark"
                               asp-area=""
                               asp-controller="Login"
                               asp-action="displayLoginPage">
                                Login
                            </a>

                            <a class="btn me-3 bg-light text-dark"
                               asp-area=""
                               asp-controller="Login"
                               asp-action="displayRegisterPage">
                                Register
                            </a>

                        }

                    </div>
                </div>
                        
            </div>

        </nav>
    </header>
    <div>
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    
    @await RenderSectionAsync("Scripts", required: false)
    
    <!-- Copyright Section -->
    <footer>
        <small>&copy; 2026 SKR International School. All rights reserved.</small>
    </footer>

   
    </body>
</html>
