@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> signInManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Application</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DevApp.styles.css" asp-append-version="true" />

    <style>
        html, body {
            height: 100%; /* full viewport height */
            margin: 0;
            display: flex;
            flex-direction: column;
            padding-top:20px;
        }

        main {
            flex: 1; /* pushes footer down */
            min-height: 600px; /* ensures footer after certain height */
        }

        footer {
            background-color: #343a40;
            color: #fff;
            text-align: center;
            padding: 15px 0;
        }
    </style>

</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow fixed-top shadow">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    SKR International School
                </a>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area=""
                               asp-controller="Home"
                               asp-action="Index">
                                Home
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">
                                About
                            </a>

                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item"
                                       asp-area=""
                                       asp-controller="Home"
                                       asp-action="displayAboutUs">
                                        About Us
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-area=""
                                       asp-controller="Home"
                                       asp-action="displayDirectorMessage">
                                        Director's Desk
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-area=""
                                       asp-controller="SuperAdmin"
                                       asp-action="GetIndividualStudentDetailsByRegistrationId">
                                        Principal's Message
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-area=""
                                       asp-controller="SuperAdmin"
                                       asp-action="GetIndividualStudentDetailsByRegistrationId">
                                        History
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-area=""
                                       asp-controller="SuperAdmin"
                                       asp-action="GetIndividualStudentDetailsByRegistrationId">
                                        Managing Committee
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-area=""
                                       asp-controller="SuperAdmin"
                                       asp-action="GetIndividualStudentDetailsByRegistrationId">
                                        Fee Structure
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-area=""
                                       asp-controller="SuperAdmin"
                                       asp-action="GetIndividualStudentDetailsByRegistrationId">
                                        Infrastructure
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-area=""
                                       asp-controller="SuperAdmin"
                                       asp-action="GetIndividualStudentDetailsByRegistrationId">
                                        Aims and Objectives
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-area=""
                                       asp-controller="Home"
                                       asp-action="displayGallery">
                                        Gallery
                                    </a>
                                </li>

                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-light"
                               asp-area=""
                               asp-controller="Home"
                               asp-action="Index">
                                Admission Process
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-light"
                               asp-area=""
                               asp-controller="Home"
                               asp-action="Index">
                                Academic Calender
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-light"
                               asp-area=""
                               asp-controller="Home"
                               asp-action="displayContactUsPage">
                                Contact Us
                            </a>
                        </li>

                       @*  <li class="nav-item dropdown">


                            <a class="nav-link dropdown-toggle"
                               role="button"
                               data-bs-toggle="dropdown"
                               id="myDropdown"
                               aria-expanded="false">
                                Student Corner
                            </a>


                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="SuperAdmin" asp-action="GetStudentDetails">All Student Details</a>
                                </li>

                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="SuperAdmin" asp-action="GetIndividualStudentDetailsByRegistrationId">Individual Student Details</a>
                                </li>


                            </ul>


                        </li> *@

                       @*  <li class="nav-item dropdown">
                          <a class="nav-link dropdown-toggle"
                               role="button"
                               data-bs-toggle="dropdown"
                               id="myDropdown"
                               aria-expanded="false">
                                Educator Corner
                            </a>

                            <ul class="dropdown-menu dropdown-menu-dark">

                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="SuperAdmin" asp-action="GetEducatorDetails">Educator Details</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="SuperAdmin" asp-action="GetIndividualEducatorDetailsByRegistrationId">Individual Educator Details</a>
                                </li>
                            </ul> 
                        </li> *@
                            @if (signInManager.IsSignedIn(User) && User.IsInRole("Admin"))
                            {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle"
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                    Admin
                                </a>
                                <ul class="dropdown-menu">
                                    <li>
                                        <a class="dropdown-item"
                                           asp-area=""
                                           asp-controller="SuperAdmin"
                                           asp-action="GetStudentDetails">
                                            All Student Details
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item"
                                           asp-area=""
                                           asp-controller="SuperAdmin"
                                           asp-action="GetIndividualStudentDetailsByRegistrationId">
                                            Individual Student Details
                                        </a>
                                    </li>


                                    <li>
                                        <a class="dropdown-item"
                                           asp-area=""
                                           asp-controller="SuperAdmin"
                                           asp-action="GetEducatorDetails">
                                            All Educator Details
                                        </a>
                                    </li>


                                    <li>
                                        <a class="dropdown-item"
                                           asp-area=""
                                           asp-controller="SuperAdmin"
                                           asp-action="GetIndividualEducatorDetailsByRegistrationId">
                                            Individual Educator Details
                                        </a>
                                    </li>

                                </ul>
                            </li>
                        }

                        else
                        @if (signInManager.IsSignedIn(User) && User.IsInRole("Educator"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle"
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                    Educator corner
                                </a>

                                <ul class="dropdown-menu">
                                    <li>
                                        <a class="dropdown-item"
                                           asp-area=""
                                           asp-controller="SuperAdmin"
                                           asp-action="GetStudentDetails">
                                            My Details
                                        </a>
                                    </li>

                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle"
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                    Student corner
                                </a>

                                <ul class="dropdown-menu">

                                    <li>
                                        <a class="dropdown-item"
                                           asp-area=""
                                           asp-controller="SuperAdmin"
                                           asp-action="GetStudentDetails">
                                            Student Details
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item"
                                           asp-area=""
                                           asp-controller="SuperAdmin"
                                           asp-action="GetIndividualStudentDetailsByRegistrationId">
                                            Individual Student Details
                                        </a>
                                    </li>

                                </ul>
                            </li>
                        }

                        else
                        @if (signInManager.IsSignedIn(User) && User.IsInRole("Student"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle"
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                    Student Corner
                                </a>
                                <ul class="dropdown-menu">
                                    <li>
                                        <a class="dropdown-item"
                                           asp-area=""
                                           asp-controller="SuperAdmin"
                                           asp-action="GetStudentDetails">
                                            My Details
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item"
                                           asp-area=""
                                           asp-controller="SuperAdmin"
                                           asp-action="GetIndividualStudentDetailsByRegistrationId">
                                            My Details
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }

                    </ul>


                    <div class="d-flex align-items-center">

                        @if (signInManager.IsSignedIn(User))
                        {
                            <div class="me-3 text-light">@User?.Identity?.Name </div>

                            <a class="btn me-3 bg-light text-dark"
                               asp-area=""
                               asp-controller="Login"
                               asp-action="Logout">
                                Logout
                            </a>
                        }
                        else
                        {
                            <a class="btn me-3 bg-light text-dark"
                               asp-area=""
                               asp-controller="Login"
                               asp-action="displayLoginPage">
                                Login
                            </a>

                            <a class="btn me-3 bg-light text-dark"
                               asp-area=""
                               asp-controller="Login"
                               asp-action="displayRegisterPage">
                                Register
                            </a>

                        }

                    </div>

                </div>
            </div>
        </nav>
    </header>
    <div>
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>


    <div class="container py-5">
        <div class="row">

            <!-- School Intro -->
            <div class="col-md-3 mb-4">
                <h4 class="fw-bold text-primary">SKR International School</h4>
                <p class="small text-primary text-dark">
                    Inspiring Excellence. Building Future Leaders since 1995.
                    Providing world-class CBSE education with a focus on holistic student development.
                </p>
                <!-- Social Icons -->
                <div class="d-flex gap-3 text-dark">
                    <a href="#" class="text-primary"><i class="bi bi-facebook fs-4"></i></a>
                    <a href="#" class="text-primary"><i class="bi bi-instagram fs-4"></i></a>
                    <a href="#" class="text-primary"><i class="bi bi-youtube fs-4"></i></a>
                </div>
            </div>

            <!-- Quick Links -->
            <div class="col-md-3 mb-4 text-dark">
                <h5 class="fw-bold text-primary">Quick Links</h5>
                <ul class="list-unstyled">
                    <li><a asp-controller="Home" asp-action="Index" class="text-primary text-dark">Home</a></li>
                    <li><a asp-controller="Home" asp-action="displayAboutUs" class="text-primary text-dark">About Us</a></li>
                    <li><a asp-controller="Home" asp-action="displayGallery" class="text-primary text-dark">Gallery</a></li>
                    <li><a asp-controller="Home" asp-action="Index" class="text-primary text-dark">Academics</a></li>
                    <li><a asp-controller="Admissions" asp-action="Index" class="text-primary text-dark">Admissions</a></li>
                    <li><a asp-controller="Facilities" asp-action="Index" class="text-primary text-dark">Facilities</a></li>
                    <li><a asp-controller="Home" asp-action="Calendar" class="text-primary text-dark">Calendar</a></li>
                </ul>
            </div>

            <!-- Contact Us -->
            <div class="col-md-3 mb-4">
                <h5 class="fw-bold text-primary">Contact Us</h5>
                <p class="small text-primary text-dark mb-1">📍 SKR Campus, Patna, Patna – 411042</p>
                <p class="small text-primary text-dark mb-1">📞 020 – 12345678, 020 – 87654321</p>
                <p class="small text-primary text-dark mb-1">✉️ info@skrschool.com</p>
                <p class="small text-primary text-dark">🕒 Mon–Sat: 8:00 AM – 4:00 PM</p>
            </div>

            <!-- Newsletter -->
            <div class="col-md-3 mb-4">
                <h5 class="fw-bold text-primary">Newsletter</h5>
                <p class="small text-primary text-dark">Stay updated with school news and events. Subscribe to our newsletter.</p>
                <form class="d-flex">
                    <input type="email" class="form-control me-2" placeholder="Enter email" />
                    <button type="submit" class="btn btn-primary">Subscribe</button>
                </form>

                <!-- School App -->
                <div class="mt-3">
                    <h6 class="fw-bold text-primary text-dark">Download Our School App</h6>
                    <p class="small text-primary text-dark">Stay connected — attendance, notices & results on the go.</p>
                    <a href="#" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-google-play"></i> Get it on Google Play
                    </a>
                </div>
            </div>
        </div>
    </div>


    <!-- Copyright Section -->
    <footer>
        <small>&copy; 2026 SKR International School. All rights reserved.</small>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
