@model IEnumerable<SchoolManagementApplicationDAL.Model.EducatorDetails>

@{
    ViewData["Title"] = "ABC International School - Educator details.";
    Layout = "~/Views/_Layout.cshtml";
}

<div class="container py-4">
    <div class="row align-items-center g-4">
        <!-- Text Section -->
        <div class="col-12 col-lg-8">
            <h2 class="fw-bold text-primary mb-3">
                ABC International School
            </h2>
            <h4 class="text-secondary mb-3">
                Educator Details
            </h4>
            <p class="lead text-muted">
                Meet our dedicated educators who inspire, guide, and nurture students every day.
                This section highlights their qualifications, classes, and the passion they bring
                to shaping young minds.
            </p>
            <p>
                Explore the profiles below to learn more about the mentors who form the heart of
                our institution and contribute to its excellence.
            </p>
        </div>

        <!-- Image Section -->
        <div class="col-12 col-lg-4 text-center">
            <img src="~/pexels-photo-57690.jpeg" class="img-fluid rounded shadow-sm" alt="Educator illustration" />
        </div>
    </div>
</div>



<!-- Educator Table -->
<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-12">
            <!-- Scrollable wrapper -->
            <div class="table-responsive">
                <table class="table table-striped table-bordered table-hover align-middle text-center shadow">
                    <thead class="table-dark">
                    <tr>
                    <th>
                        @Html.DisplayNameFor(model => model.EducatorId)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.EducatorFirstName)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.EducatorMiddleName)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.EducatorLastName)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.EducatorFullName)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.EducatorDepartmentName)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.EducatorClassesAssigned)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.EducatorAddressLine1)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.EducatorAddressLine2)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.EducatorFullAddress)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.EducatorCity)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.EducatorState)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.EducatorCountry)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.EducatorPhoneNumber)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.EmailId)
                    </th>
                    <th style="min-width:200px;">Actions</th>

                   </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.EducatorId)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.EducatorFirstName)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.EducatorMiddleName)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.EducatorLastName)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.EducatorFullName)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.EducatorDepartmentName)
                        </td>

                        <td>
                            @Html.DisplayFor(modelItem => item.EducatorClassesAssigned)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.EducatorAddressLine1)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.EducatorAddressLine2)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.EducatorFullAddress)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.EducatorCity)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.EducatorState)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.EducatorCountry)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.EducatorPhoneNumber)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.EmailId)
                        </td>
                        <td class="d-flex justify-content-around" style="min-width:200px;">
                            @Html.ActionLink("Edit", "Edit", new { /* id=item.PrimaryKey */ }) |
                            @Html.ActionLink("Details", "Details", new { /* id=item.PrimaryKey */ }) |
                            @Html.ActionLink("Delete", "Delete", new { /* id=item.PrimaryKey */ })
                        </td>
                    </tr>
                }
            </tbody>
            </table>
            </div>
        </div>
    </div>
</div>


@{
    var recordsPerPage = 10;
    var totalRecords = ViewBag.TotalRecords == null ? 0 : ViewBag.TotalRecords;
    int numberOfButtons;
    if (totalRecords % recordsPerPage == 0)
    {
        numberOfButtons = totalRecords / recordsPerPage;
    }
    else
    {
        numberOfButtons = (totalRecords / recordsPerPage) + 1;
    }

    int currentPage = ViewBag.CurrentPage == null ? 1 : (int)ViewBag.CurrentPage;
}

<nav aria-label="Page navigation example">

    <ul class="pagination justify-content-center">
        <!-- Previous -->
        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
            <a class="page-link" asp-controller="Educator" asp-action="GetEducatorDetails" asp-route-page="@(currentPage - 1)">Previous</a>
        </li>

        <!-- Page Numbers -->
        @for (int i = 1; i <= numberOfButtons; i++)
        {
            <li class="page-item @(i == currentPage ? "active" : "")">
                <a class="page-link" asp-controller="Educator" asp-action="GetEducatorDetails" asp-route-page="@i">@i</a>


            </li>
        }

        <!-- Next -->
        <li class="page-item @(currentPage == numberOfButtons ? "disabled" : "")">
            <a class="page-link" asp-controller="Educator" asp-action="GetEducatorDetails" asp-route-page="@(currentPage + 1)">Next</a>
        </li>
    </ul>
</nav>

